<div class="container mx-auto p-8 bg-white shadow-lg rounded-lg mt-10">
  <h1 class="text-center text-3xl font-bold mb-6 text-gray-800">Book an Appointment</h1>

  <%= form_with model: @appointment, url: appointments_path, class: "space-y-6" do |form| %>
    
    <!-- First Name -->
    <div class="form-group">
      <%= form.label :firstname, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :firstname, class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm focus:ring focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <!-- Last Name -->
    <div class="form-group">
      <%= form.label :lastname, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :lastname, class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm focus:ring focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <!-- Department -->
    <div class="form-group">
      <%= form.label :department, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :department, class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm focus:ring focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <!-- Reasons -->
    <div class="form-group">
      <%= form.label :reasons, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_area :reasons, rows: 4, class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm focus:ring focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <!-- Appointment Date -->
    <div class="form-group">
      <%= form.label :appointment_date, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.datetime_select :appointment_date, { start_day: Date.today, minute_step: 30 }, class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm focus:ring focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <!-- Submit Button -->
    <div class="form-group">
      <%= form.submit "Book Appointment", class: "w-full py-2 px-4 bg-blue-600 text-white font-semibold rounded-md shadow hover:bg-blue-700 transition duration-200" %>
    </div>

  <% end %>
</div>